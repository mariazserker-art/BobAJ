local function startInfiniteHop(label)
    print("[HOP] Iniciando...")
    if not game:IsLoaded() then game.Loaded:Wait() end
    task.wait(1)
    visitedServers[game.JobId] = os.time()
    while true do
        local ok, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(
                "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Asc&limit=100"
            ))
        end)
        if ok and result and result.data then
            local now = os.time()
            for id, ts in pairs(visitedServers) do
                if now - ts > VISITED_EXPIRY then visitedServers[id] = nil end
            end
            for _, server in ipairs(result.data) do
                if server.id ~= game.JobId and not visitedServers[server.id] then
                    text.Text = "📡 " .. label .. " - " .. string.sub(server.id, 1, 8) .. "..."
                    print("[HOP] Tentando: " .. server.id)
                    visitedServers[server.id] = os.time()
                    TeleportService:TeleportToPlaceInstance(PLACE_ID, server.id, LocalPlayer)
                    task.wait(2)
                end
            end
        else
            text.Text = "⏳ Sem servidores..."
            task.wait(3)
        end
        task.wait(0.5)
    end
end

