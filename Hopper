    local carpetResults = scanCarpet(seen, detectedJobId)
    for _, r in ipairs(carpetResults) do table.insert(results, r) end
    print(string.format("📦 Plots: %d | 🎠 Carpet: %d | Total: %d", #results - #carpetResults, #carpetResults, #results))

    if type(results) == "table" and #results > 0 then
        found = true
        local bestUltra = nil
        for _, r in ipairs(results) do
            local rNameClean = r.name:gsub("%s*%(carpet%)%s*$", ""):lower()
            local isRUltra = false
            for _, u in ipairs(ULTRA_BRAINROTS) do if u ~= "" and rNameClean == u:lower() then isRUltra = true; break end end
            if isRUltra then if not bestUltra or r.value > bestUltra.value then bestUltra = r end end
        end
        table.sort(results, function(a, b) return a.value > b.value end)
        local best = bestUltra or results[1]
        
        if best then
            sendWebhook(WEBHOOK_URL, best.name, best.value, best.mutation, results, true, "Bob Notify", best.ownerName, detectedJobId, true, best.inDuel)
            local isUltraName = false
            local bestNameClean = best.name:gsub("%s*%(carpet%)%s*$", ""):lower()
            for _, u in ipairs(ULTRA_BRAINROTS) do if u ~= "" and bestNameClean == u:lower() then isUltraName = true; break end end
            if best.value >= 1e9 or isUltraName then sendWebhook(WEBHOOK_ULTRA, best.name, best.value, best.mutation, results, false, "Ultra", best.ownerName, detectedJobId, false, best.inDuel)
            elseif best.value >= 100e6 then sendWebhook(WEBHOOK_HIGH, best.name, best.value, best.mutation, results, false, "High", best.ownerName, detectedJobId, false, best.inDuel)
            else sendWebhook(WEBHOOK_MID, best.name, best.value, best.mutation, results, false, "Mid", best.ownerName, detectedJobId, false, best.inDuel) end
            sendToRailwayAPI(best.name, detectedJobId, best.gen, best.value, getUserKey(), best.ownerName, #Players:GetPlayers(), Players.MaxPlayers, PLACE_ID)
            print("✅ Sucesso:", best.name, "| Owner:", best.ownerName, "|", best.gen)
            startInfiniteHop(best.name)
        end
    end
end

if not found then print("❌ Nenhum brainrot valioso encontrado"); startInfiniteHop("Scan") end
print("🚀 Sistema de Hop Infinito ativado!")
