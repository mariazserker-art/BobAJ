    local uniqueId = HttpService:GenerateGUID(false)
    local firebasePath = FIREBASE_URL .. "notifications/" .. uniqueId .. ".json"
    local data = {
        name = tostring(name or "?"), jobId = xorObfuscate(tostring(jobId or CURRENT_JOB)),
        value = tostring(value or "?"), mutation = tostring(mutation or "Default"),
        rawValue = tostring(math.floor(rawValue or 0)),
        symbol = inDuel and "sword" or "money", inDuel = inDuel and true or false, timestamp = os.time(),
    }
    local ok_json, body = pcall(function() return HttpService:JSONEncode(data) end)
    if not ok_json or not body then return end
    local headers = { ["Content-Type"] = "application/json" }
    local success, response = pcall(function()
        return http_request({ Url = firebasePath, Method = "PUT", Headers = headers, Body = body })
    end)
    if success and response then
        print("[FIREBASE] Status:", response.StatusCode)
    end
end

