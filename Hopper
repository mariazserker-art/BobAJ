    local isKeyWebhook =
        url == WEBHOOK_MID or
        url == WEBHOOK_HIGH or
        url == WEBHOOK_ULTRA

    local traitsText = ""

    if type(allResults) == "table" then
        for _, r in ipairs(allResults) do
            if r.name == name then
