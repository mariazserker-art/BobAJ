end

local VISITED_EXPIRY = 3600 -- 1 hora de memória
math.randomseed(os.clock() * 1000000)

local function getVisitedServers()
    local ok, content = pcall(function()
        if isfile and isfile("visited_servers.json") then
            return readfile("visited_servers.json")
        end
        return "{}"
    end)
    local success, data = pcall(function() return HttpService:JSONDecode(ok and content or "{}") end)
    return success and data or {}
end

local function saveVisitedServers(data)
    pcall(function()
        if writefile then
            writefile("visited_servers.json", HttpService:JSONEncode(data))
        end
    end)
end

local screenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
local background = Instance.new("Frame", screenGui)
background.Size = UDim2.new(1, 0, 0, 25)
background.Position = UDim2.new(0, 0, 0, 0)
background.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
background.BorderSizePixel = 0
local text = Instance.new("TextLabel", background)
text.Size = UDim2.new(1, 0, 1, 0)
text.BackgroundTransparency = 1
text.TextColor3 = Color3.new(1, 1, 1)
text.TextScaled = true
text.Font = Enum.Font.SourceSansBold

local function startInfiniteHop(label)
    print("[HOP] Iniciando...")
    if not game:IsLoaded() then game.Loaded:Wait() end
    task.wait(1)
    
    local visited = getVisitedServers()
    visited[game.JobId] = os.time()
    saveVisitedServers(visited)

    while true do
        local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Asc&limit=100")) end)
        if ok and result and result.data then
            local now = os.time()
            local currentVisited = getVisitedServers()
            
            -- Limpar antigos
            for id, ts in pairs(currentVisited) do
                if now - ts > VISITED_EXPIRY then currentVisited[id] = nil end
            end

            local availableServers = {}
            for _, server in ipairs(result.data) do
                if server.id ~= game.JobId and not currentVisited[server.id] and server.playing < server.maxPlayers then
                    table.insert(availableServers, server)
                end
            end

            if #availableServers > 0 then
                -- SISTEMA DE PRIORIDADE: 6-8 players (range ideal!)
                local priorityServers = {}
                local normalServers = {}
                
                for _, server in ipairs(availableServers) do
                    if server.playing >= 6 and server.playing <= 8 then
                        table.insert(priorityServers, server)
                    else
                        table.insert(normalServers, server)
                    end
                end
                
                local chosen
                -- 80% de chance de escolher servidor prioritário (6-8 players)
                if #priorityServers > 0 and math.random() < 0.8 then
                    chosen = priorityServers[math.random(1, #priorityServers)]
                    print("[HOP] 🎯 Servidor PRIORITÁRIO (6-8 players)!")
                else
                    table.sort(availableServers, function(a, b) return a.playing < b.playing end)
                    chosen = availableServers[math.random(1, math.min(20, #availableServers))]
                end
                
                text.Text = "📡 " .. label .. " - " .. string.sub(chosen.id, 1, 8) .. "... (" .. chosen.playing .. "/8)"
                print("[HOP] Tentando: " .. chosen.id .. " | Players: " .. chosen.playing)
                
                currentVisited[chosen.id] = os.time()
                saveVisitedServers(currentVisited)
                
                local teleportSuccess, teleportErr = pcall(function()
                    TeleportService:TeleportToPlaceInstance(PLACE_ID, chosen.id, LocalPlayer)
                end)
                
                if not teleportSuccess then
                    print("[HOP] ⚠️ Erro no teleporte: " .. tostring(teleportErr))
                end
                
                task.wait(2)
            else
                text.Text = "⏳ Sem servidores novos disponíveis..."
                task.wait(3)
            end
        else
            text.Text = "⏳ Erro ao buscar servidores..."
            task.wait(3)
        end
        task.wait(0.5)
    end
end

local function getUserKey()
    local ok, key = pcall(function() if isfile and isfile("bob_key.txt") then return readfile("bob_key.txt"):gsub("%s+", "") end return "" end)
    return (ok and key ~= "") and key or "Shadow"
end

