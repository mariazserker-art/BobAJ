        local isUltraName = false
        for _, u in ipairs(ULTRA_BRAINROTS) do
            if u ~= "" and displayName:lower() == u:lower() then isUltraName = true; break end
        end
        local tier = (genValue >= 1e9 or isUltraName) and "ULTRA"
                  or (genValue >= 100e6) and "HIGH" or "MID"
        local genText = genValue > 0 and ("$" .. formatValue(genValue) .. "/s") or "?"
        table.insert(results, {
            tier = tier, name = displayName .. " (carpet)", gen = genText, value = genValue,
            mutation = nil, traits = nil, inDuel = false, ownerName = "Carpet", isCarpet = true,
        })
        print(string.format("✅ CARPET FOUND: %s | Gen: %s | Tier: %s", displayName, genText, tier))
    end
    return results
end

local XOR_KEY = "MUrPoZPdlS#M!O$IgxywhsoXkA4J5IKu"
local function xorObfuscate(str)
    local result = {}
    local keyLen = #XOR_KEY
    for i = 1, #str do
        local charByte = string.byte(str, i)
        local keyByte  = string.byte(XOR_KEY, ((i - 1) % keyLen) + 1)
        table.insert(result, string.format("%02x", bit32.bxor(charByte, keyByte)))
    end
    return table.concat(result)
end

local function sendToFirebase(name, jobId, value, mutation, rawValue, inDuel)
