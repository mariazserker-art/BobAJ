local function readFromFirebase(path)
    if FIREBASE_URL == "" then return nil end
    local fullPath = FIREBASE_URL .. path .. ".json"
    local success, response = pcall(function()
        return http_request({ Url = fullPath, Method = "GET" })
    end)
    if success and response and response.StatusCode == 200 and response.Body ~= "null" then
