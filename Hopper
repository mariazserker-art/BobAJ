            { type = 14, divider = true, spacing = 1 },
            { type = 9, accessory = imageUrl and { type = 11, media = { url = imageUrl } } or nil,
                components = {{ type = 10, content = "# " .. mutEmoji .. "・" .. name .. "\n" .. (traitsText ~= "" and (traitsText .. "\n") or "") .. "### " .. genText }}
            }
        }
    }}

    if #otherBrainrots > 0 then
        table.insert(components[1].components, { type = 14, divider = true, spacing = 1 })
        table.insert(components[1].components, { type = 10, content = "**Other**\n" .. table.concat(otherBrainrots, "\n") })
    end

    table.insert(components[1].components, { type = 14, divider = true, spacing = 1 })
    if not isKeyWebhook then
        table.insert(components[1].components, { type = 10, content = "## <:id2:1502543195488256160> • Job ID\n\n`" .. tostring(jobId or CURRENT_JOB) .. "`" })
        table.insert(components[1].components, { type = 1, components = {{ type = 2, style = 5, label = "Click Here To Join!", url = joinLink, emoji = { id = "1502063760024801331" } }} })
    else
        table.insert(components[1].components, { type = 1, components = {{ type = 2, style = 5, label = "Click Here To Buy Your Key!", url = "https://discord.com/channels/1477872742933069846/1477912919441408101", emoji = { id = "1502528698757156924" } }} })
    end
    table.insert(components[1].components, { type = 14, divider = true, spacing = 1 })
    table.insert(components[1].components, { type = 10, content = footerText })

    pcall(function()
        http_request({
            Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({ username = NOTIFIER_NAME, flags = 32768, components = components })
        })
    end)
end

