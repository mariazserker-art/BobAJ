local function startInfiniteHop(label)
    print("[HOP] Iniciando varredura sequencial para QUALQUER servidor...")
    if not game:IsLoaded() then game.Loaded:Wait() end
    task.wait(1)
    
    local visited = getVisitedServers()
    visited[game.JobId] = os.time()
    saveVisitedServers(visited)

    while true do
        local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Asc&limit=100")) end)
        if ok and result and result.data then
            local now = os.time()
            local currentVisited = getVisitedServers()
            
            for id, ts in pairs(currentVisited) do if now - ts > VISITED_EXPIRY then currentVisited[id] = nil end end

            local targetServers = {}
            for _, server in ipairs(result.data) do
                if server.id ~= game.JobId and not currentVisited[server.id] and server.playing < server.maxPlayers then
                    table.insert(targetServers, server)
                end
            end

            -- Embaralha a lista para aleatoriedade
            local shuffled = {}
            while #targetServers > 0 do table.insert(shuffled, table.remove(targetServers, math.random(1, #targetServers))) end

            if #shuffled > 0 then
                for _, chosen in ipairs(shuffled) do
                    text.Text = "🚀 Tentando server: " .. chosen.playing .. " players (" .. string.sub(chosen.id, 1, 5) .. ")"
                    print("[HOP] Tentando entrar: " .. chosen.id .. " | Players: " .. chosen.playing)
                    
                    currentVisited[chosen.id] = os.time()
                    saveVisitedServers(currentVisited)
                    
                    local teleportSuccess, teleportErr = pcall(function() TeleportService:TeleportToPlaceInstance(PLACE_ID, chosen.id, LocalPlayer) end)
                    if teleportSuccess then task.wait(5) else print("[HOP] Erro: " .. tostring(teleportErr)); task.wait(0.5) end
                end
            else
                text.Text = "⏳ Nenhum servidor disponível no momento. Aguardando..."
                task.wait(10)
            end
        else
            text.Text = "⏳ Erro ao buscar servidores..."
            task.wait(5)
        end
        task.wait(0.5)
    end
end

